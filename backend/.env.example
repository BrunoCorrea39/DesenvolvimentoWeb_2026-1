# Banco de dados
# SQLite (dev sem Docker):
# DATABASE_URL=sqlite:///./projetai.db
# PostgreSQL (Docker / producao):
DATABASE_URL=postgresql+psycopg://projetai:projetai@localhost:5432/projetai

# Credenciais do Postgres (usadas pelo docker-compose)
POSTGRES_USER=projetai
POSTGRES_PASSWORD=projetai
POSTGRES_DB=projetai

# Seguranca
JWT_SECRET_KEY=troque-esta-chave-em-producao
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# IA (Claude API)
ANTHROPIC_API_KEY=sua-chave-da-claude-api
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_VERSION=2023-06-01
